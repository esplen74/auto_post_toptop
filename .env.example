GOOGLE_SHEET_ID=
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json
USERS_CONFIG_PATH=./config/users.json

# Chrome Profiles Base Directory
# Default: ../chrome-profiles (relative to project root)
# Each user profile stored at: <CHROME_PROFILES_DIR>/<user.name>
# Windows: D:\\workspace\\chrome-profiles or D:/workspace/chrome-profiles
# macOS/Linux: ~/projects/chrome-profiles or ../chrome-profiles
CHROME_PROFILES_DIR=../chrome-profiles

# Video Files Directory
# Windows: D:\\videos or D:/videos
# macOS/Linux: ~/videos or ../videos
VIDEO_ROOT=../videos

# Test video for dry-run testing (relative to VIDEO_ROOT)
TEST_VIDEO=test.mp4

# TikTok Upload Page
TIKTOK_UPLOAD_URL=https://www.tiktok.com/tiktokstudio/upload?from=creator_center&tab=video

# Upload Configuration
UPLOAD_LIMIT_PER_RUN=3

# Browser Configuration
HEADLESS=false
DRY_RUN=true
